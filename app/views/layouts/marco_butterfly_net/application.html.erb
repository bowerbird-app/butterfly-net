<!DOCTYPE html>
<html lang="en">
<head>
  <title>MarcoButterflyNet - Error Tracking Dashboard</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= yield :head %>

  <%# Tailwind Play CDN - for development/internal dashboards. For production deployments
