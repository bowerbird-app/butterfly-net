<% content_for :page_title, @exception_class %>

<%= render FlatPack::PageHeader::Component.new(title: @exception_class, subtitle: @group_by == ButterflyNet::DashboardController::GROUP_BY_IP ? "Distinct IP addresses for this exception: #{@pagy.count}" : "Distinct errors for this exception: #{@pagy.count}") %>

<%= render FlatPack::Breadcrumb::Component.new(separator: :chevron) do |breadcrumb| %>
  <% breadcrumb.item(text: "Dashboard", href: dashboard_index_path) %>
  <% breadcrumb.item(text: @exception_class) %>
<% end %>

<% message_group_path = grouped_dashboard_index_path(exception_class: @exception_class, group_by: ButterflyNet::DashboardController::GROUP_BY_MESSAGE) %>
<% ip_group_path = grouped_dashboard_index_path(exception_class: @exception_class, group_by: ButterflyNet::DashboardController::GROUP_BY_IP) %>

<%= render FlatPack::SegmentedButtons::Component.new(class: "mt-6") do |group| %>
  <% group.button(
    text: "Message grouped",
    selected: @group_by == ButterflyNet::DashboardController::GROUP_BY_MESSAGE,
    size: :sm,
    url: message_group_path
  ) %>
  <% group.button(
    text: "IP address grouped",
    selected: @group_by == ButterflyNet::DashboardController::GROUP_BY_IP,
    size: :sm,
    url: ip_group_path
  ) %>
<% end %>

<div class="mt-8" id="error-logs-container" data-current-page="<%= @pagy.page %>" data-has-more="<%= @pagy.next.present? %>" data-base-url="<%= grouped_dashboard_index_path(exception_class: @exception_class, group_by: @group_by) %>" data-view-mode="<%= @group_by == ButterflyNet::DashboardController::GROUP_BY_IP ? "grouped-ip" : "grouped-message" %>">
  <% if @group_by == ButterflyNet::DashboardController::GROUP_BY_IP %>
    <div data-ip-groups>
      <% @error_logs.each do |group| %>
        <section class="mb-8 last:mb-0">
          <p class="mb-4 text-sm font-medium text-gray-700">
            IP address: <span class="text-gray-900"><%= group[:ip_address] %></span>
          </p>
          <%= render "error_logs_table", error_logs: group[:error_logs] %>
        </section>
      <% end %>
    </div>
  <% else %>
    <%= render "error_logs_table", error_logs: @error_logs %>
  <% end %>
  <div id="scroll-sentinel" style="height: 1px;"></div>
  <div id="loading-indicator" class="hidden text-center py-4">
    <div class="inline-flex items-center gap-2 text-gray-600">
      <svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      <span>Loading more errors...</span>
    </div>
  </div>
</div>