<div data-controller="analytics"
     data-analytics-summary-url-value="<%= butterfly_net.analytics_summary_path %>"
     data-analytics-top-errors-url-value="<%= butterfly_net.analytics_top_errors_path %>"
     data-analytics-time-series-url-value="<%= butterfly_net.analytics_time_series_path %>">
    <!-- Header -->
    <div class="px-4 sm:px-6 lg:px-8 mb-8">
      <%= render FlatPack::PageHeader::Component.new(
        title: "Analytics Dashboard",
        subtitle: "Monitor error trends, user impact, and performance metrics"
      ) %>
    </div>

    <!-- Summary KPI Cards -->
    <div class="px-4 sm:px-6 lg:px-8 mb-8">
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4" id="kpi-cards">
        <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
          <% card.body do %>
            <dt class="text-sm font-medium text-gray-500 truncate">Total Open Errors</dt>
            <dd class="mt-1 text-3xl font-semibold text-gray-900" id="kpi-open-errors">-</dd>
          <% end %>
        <% end %>

        <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
          <% card.body do %>
            <dt class="text-sm font-medium text-gray-500 truncate">Users Affected Today</dt>
            <dd class="mt-1 text-3xl font-semibold text-gray-900" id="kpi-affected-users">-</dd>
          <% end %>
        <% end %>

        <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
          <% card.body do %>
            <dt class="text-sm font-medium text-gray-500 truncate">Mean Time to Resolution</dt>
            <dd class="mt-1 text-3xl font-semibold text-gray-900" id="kpi-mttr">-</dd>
          <% end %>
        <% end %>

        <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
          <% card.body do %>
            <dt class="text-sm font-medium text-gray-500 truncate">Occurrences Today</dt>
            <dd class="mt-1 text-3xl font-semibold text-gray-900" id="kpi-occurrences">-</dd>
          <% end %>
        <% end %>
      </div>
    </div>

    <!-- Charts Grid -->
    <div class="px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        <!-- Status Breakdown Chart -->
        <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
          <% card.header do %>
            <h3 class="text-lg font-medium text-gray-900">Error Status Breakdown</h3>
          <% end %>
          <% card.body do %>
            <div id="status-chart"></div>
          <% end %>
        <% end %>

        <!-- Top Errors Chart -->
        <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
          <% card.header do %>
            <h3 class="text-lg font-medium text-gray-900">Top 10 Most Frequent Errors</h3>
          <% end %>
          <% card.body do %>
            <div id="top-errors-chart"></div>
          <% end %>
        <% end %>

        <!-- Affected Users Over Time -->
        <div class="lg:col-span-2">
          <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
            <% card.header do %>
              <h3 class="text-lg font-medium text-gray-900">Affected Users Over Time (Last 30 Days)</h3>
            <% end %>
            <% card.body do %>
              <div id="users-chart"></div>
            <% end %>
          <% end %>
        </div>

        <!-- Error Occurrences Over Time -->
        <div class="lg:col-span-2">
          <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
            <% card.header do %>
              <h3 class="text-lg font-medium text-gray-900">Error Occurrences Over Time (Last 30 Days)</h3>
            <% end %>
            <% card.body do %>
              <div id="occurrences-chart"></div>
            <% end %>
          <% end %>
        </div>

        <!-- New Errors Over Time -->
        <div class="lg:col-span-2">
          <%= render FlatPack::Card::Component.new(style: :outlined) do |card| %>
            <% card.header do %>
              <h3 class="text-lg font-medium text-gray-900">New Errors Discovered Over Time (Last 30 Days)</h3>
            <% end %>
            <% card.body do %>
              <div id="new-errors-chart"></div>
            <% end %>
          <% end %>
        </div>
      </div>
    </div>
</div>


