<% content_for :page_title, "Analytics" %>

<%= render FlatPack::PageHeader::Component.new(title: "Analytics", subtitle: @date_range.label) %>

<div class="mb-8 rounded-lg border border-gray-200 bg-white p-4">
  <%= form_with url: butterfly_net.analytics_path, method: :get, local: true, html: { class: "flex flex-col gap-4 sm:flex-row sm:items-end" } do %>
    <div class="flex-1">
      <label for="analytics-start-date" class="mb-2 block text-sm font-medium text-gray-700">Start date</label>
      <%= date_field_tag :start_date, @date_range.start_date.iso8601, id: "analytics-start-date", class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-900" %>
    </div>
    <div class="flex-1">
      <label for="analytics-end-date" class="mb-2 block text-sm font-medium text-gray-700">End date</label>
      <%= date_field_tag :end_date, @date_range.end_date.iso8601, id: "analytics-end-date", class: "w-full rounded-md border border-gray-300 px-3 py-2 text-sm text-gray-900" %>
    </div>
    <div class="flex gap-3">
      <%= submit_tag "Apply", class: "inline-flex items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-text" %>
      <%= link_to "Reset", butterfly_net.analytics_path, class: "inline-flex items-center justify-center rounded-md border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700" %>
    </div>
  <% end %>
</div>

<%= render FlatPack::Grid::Component.new(cols: 4, gap: :lg, id: "kpi-cards", class: "mb-8") do %>
        <!-- Cards will be populated by JavaScript -->
        <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
          <% card.body do %>
            <dt class="text-sm font-medium text-gray-500 truncate">Open Errors</dt>
            <dd class="mt-1 text-3xl font-semibold text-gray-900" id="kpi-open-errors">-</dd>
          <% end %>
        <% end %>
        <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
          <% card.body do %>
            <dt class="text-sm font-medium text-gray-500 truncate">Affected Users</dt>
            <dd class="mt-1 text-3xl font-semibold text-gray-900" id="kpi-affected-users">-</dd>
          <% end %>
        <% end %>
        <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
          <% card.body do %>
            <dt class="text-sm font-medium text-gray-500 truncate">Mean Time to Resolution</dt>
            <dd class="mt-1 text-3xl font-semibold text-gray-900" id="kpi-mttr">-</dd>
          <% end %>
        <% end %>
        <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
          <% card.body do %>
            <dt class="text-sm font-medium text-gray-500 truncate">Occurrences</dt>
            <dd class="mt-1 text-3xl font-semibold text-gray-900" id="kpi-occurrences">-</dd>
          <% end %>
        <% end %>
<% end %>
<%= render FlatPack::Grid::Component.new(cols: 2, gap: :lg) do %>
        <!-- Status Breakdown Chart -->
        <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
          <% card.header do %>
            <h3 class="text-lg font-semibold">Error Status Breakdown</h3>
          <% end %>
          <% card.body do %>
            <div id="status-chart"></div>
          <% end %>
        <% end %>

        <!-- Top Errors Chart -->
        <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
          <% card.header do %>
            <h3 class="text-lg font-semibold">Top 10 Most Frequent Errors</h3>
          <% end %>
          <% card.body do %>
            <div id="top-errors-chart"></div>
          <% end %>
        <% end %>

        <!-- Affected Users Over Time -->
        <div class="md:col-span-2">
          <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
            <% card.header do %>
              <h3 class="text-lg font-semibold">Affected Users Over Time (<%= @date_range.label %>)</h3>
            <% end %>
            <% card.body do %>
              <div id="users-chart"></div>
            <% end %>
          <% end %>
        </div>

        <!-- Error Occurrences Over Time -->
        <div class="md:col-span-2">
          <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
            <% card.header do %>
              <h3 class="text-lg font-semibold">Error Occurrences Over Time (<%= @date_range.label %>)</h3>
            <% end %>
            <% card.body do %>
              <div id="occurrences-chart"></div>
            <% end %>
          <% end %>
        </div>

        <!-- New Errors Over Time -->
        <div class="md:col-span-2">
          <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
            <% card.header do %>
              <h3 class="text-lg font-semibold">New Errors Discovered Over Time (<%= @date_range.label %>)</h3>
            <% end %>
            <% card.body do %>
              <div id="new-errors-chart"></div>
            <% end %>
          <% end %>
        </div>

<% end %>

<%= javascript_include_tag "butterfly_net/analytics", defer: true %>
