<% content_for :page_title, "Analytics" %>

<%= render FlatPack::PageHeader::Component.new(title: "Analytics") %>

<!-- Summary KPI Cards -->
<div class="mb-8">
  <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4" id="kpi-cards">
        <!-- Cards will be populated by JavaScript -->
        <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
          <% card.body do %>
            <dt class="text-sm font-medium text-gray-500 truncate">Total Open Errors</dt>
            <dd class="mt-1 text-3xl font-semibold text-gray-900" id="kpi-open-errors">-</dd>
          <% end %>
        <% end %>
        <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
          <% card.body do %>
            <dt class="text-sm font-medium text-gray-500 truncate">Users Affected Today</dt>
            <dd class="mt-1 text-3xl font-semibold text-gray-900" id="kpi-affected-users">-</dd>
          <% end %>
        <% end %>
        <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
          <% card.body do %>
            <dt class="text-sm font-medium text-gray-500 truncate">Mean Time to Resolution</dt>
            <dd class="mt-1 text-3xl font-semibold text-gray-900" id="kpi-mttr">-</dd>
          <% end %>
        <% end %>
        <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
          <% card.body do %>
            <dt class="text-sm font-medium text-gray-500 truncate">Occurrences Today</dt>
            <dd class="mt-1 text-3xl font-semibold text-gray-900" id="kpi-occurrences">-</dd>
          <% end %>
        <% end %>
  </div>
</div>

<!-- Charts Grid -->
<div>
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        <!-- Status Breakdown Chart -->
        <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
          <% card.header do %>
            <h3 class="text-lg font-semibold">Error Status Breakdown</h3>
          <% end %>
          <% card.body do %>
            <div id="status-chart"></div>
          <% end %>
        <% end %>

        <!-- Top Errors Chart -->
        <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
          <% card.header do %>
            <h3 class="text-lg font-semibold">Top 10 Most Frequent Errors</h3>
          <% end %>
          <% card.body do %>
            <div id="top-errors-chart"></div>
          <% end %>
        <% end %>

        <!-- Affected Users Over Time -->
        <div class="lg:col-span-2">
          <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
            <% card.header do %>
              <h3 class="text-lg font-semibold">Affected Users Over Time (Last 30 Days)</h3>
            <% end %>
            <% card.body do %>
              <div id="users-chart"></div>
            <% end %>
          <% end %>
        </div>

        <!-- Error Occurrences Over Time -->
        <div class="lg:col-span-2">
          <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
            <% card.header do %>
              <h3 class="text-lg font-semibold">Error Occurrences Over Time (Last 30 Days)</h3>
            <% end %>
            <% card.body do %>
              <div id="occurrences-chart"></div>
            <% end %>
          <% end %>
        </div>

        <!-- New Errors Over Time -->
        <div class="lg:col-span-2">
          <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
            <% card.header do %>
              <h3 class="text-lg font-semibold">New Errors Discovered Over Time (Last 30 Days)</h3>
            <% end %>
            <% card.body do %>
              <div id="new-errors-chart"></div>
            <% end %>
          <% end %>
        </div>
  </div>
</div>

<%= javascript_include_tag "butterfly_net/analytics", defer: true %>
