<% content_for :page_title, "Error Tracking" %>

<%= render FlatPack::PageHeader::Component.new(title: "Errors", subtitle: "Total exceptions: #{@pagy.count}") %>
<div class="mt-8" id="error-logs-container" data-current-page="<%= @pagy.page %>" data-has-more="<%= @pagy.next.present? %>" data-base-url="<%= dashboard_index_path %>" data-view-mode="index">
  <%= render FlatPack::Table::Component.new(data: @error_rows) do |table| %>
    <% table.column(title: "Exception", html: ->(error_row) { error_row[:exception_class] }) %>
    <% table.column(title: "Occurrences", html: ->(error_row) {
      content_tag(:span, error_row[:occurrence_count], class: "font-medium")
    }) %>
    <% table.column(title: "Users Affected", html: ->(error_row) {
      affected_count = error_row[:affected_count]
      if affected_count > 0
        content_tag(:span, affected_count, class: "font-medium")
      else
        content_tag(:span, "\u2014", class: "text-gray-400")
      end
    }) %>
    <% table.column(title: "Last Seen", html: ->(error_row) {
      time_ago_in_words(error_row[:last_seen]) + " ago"
    }) %>
    <% table.column(title: "", html: ->(error_row) {
      render FlatPack::Button::Component.new(text: "View", style: :ghost, size: :sm, url: error_row[:dashboard_path])
    }) %>
  <% end %>
  <!-- Sentinel element for infinite scroll detection -->
  <div id="scroll-sentinel" style="height: 1px;"></div>
  <!-- Loading indicator -->
  <div id="loading-indicator" class="hidden text-center py-4">
    <div class="inline-flex items-center gap-2 text-gray-600">
      <svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
      <span>Loading more errors...</span>
    </div>
  </div>
</div>
