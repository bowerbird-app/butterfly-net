<div class="px-4 sm:px-6 lg:px-8">
      <div class="sm:flex sm:items-center">
        <div class="sm:flex-auto">
          <%= render FlatPack::PageTitle::Component.new(
            title: "Error Tracking Dashboard",
            subtitle: "Total errors: #{@pagy.count}"
          ) %>
        </div>
        <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
          <%= render FlatPack::Button::Component.new(
            text: "View Analytics",
            style: :primary,
            url: butterfly_net.analytics_path
          ) %>
        </div>
      </div>
      <div class="mt-8 flow-root">
        <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
          <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
            <% if @error_logs.empty? %>
              <%= render FlatPack::EmptyState::Component.new(
                title: "No errors recorded yet.",
                description: "Errors will appear here once your application starts catching exceptions.",
                icon: :inbox
              ) %>
            <% else %>
              <div id="error-logs-container"
                   data-controller="infinite-scroll"
                   data-infinite-scroll-url-value="<%= butterfly_net.dashboard_index_path %>">
                <%= render FlatPack::Table::Component.new(data: @error_logs) do |table| %>
                  <% table.column(title: "Status", html: ->(error_log) {
                    case error_log.status
                    when "open"
                      render FlatPack::Badge::Component.new(text: "Open", style: :info)
                    when "in_progress"
                      render FlatPack::Badge::Component.new(text: "In Progress", style: :warning)
                    when "resolved"
                      render FlatPack::Badge::Component.new(text: "Resolved", style: :success)
                    when "dismissed"
                      render FlatPack::Badge::Component.new(text: "Dismissed", style: :default)
                    end
                  }) %>
                  <% table.column(title: "Exception", html: ->(error_log) { error_log.exception_class }) %>
                  <% table.column(title: "Message", html: ->(error_log) { truncate(error_log.message, length: 60) }) %>
                  <% table.column(title: "Occurrences", html: ->(error_log) { error_log.occurrence_count }) %>
                  <% table.column(title: "Users Affected", html: ->(error_log) {
                    unique_users  = error_log.occurrences.where.not(user_id: nil).distinct.count(:user_id)
                    unique_emails = error_log.occurrences.where.not(user_email: nil).distinct.count(:user_email)
                    affected_count = [unique_users, unique_emails].max
                    if affected_count > 0
                      content_tag(:span, affected_count, class: "font-medium")
                    else
                      content_tag(:span, "—", class: "text-gray-400")
                    end
                  }) %>
                  <% table.column(title: "Last Seen", html: ->(error_log) {
                    last_occurrence = error_log.occurrences.order(created_at: :desc).first
                    last_occurrence ? time_ago_in_words(last_occurrence.created_at) + " ago" : time_ago_in_words(error_log.created_at) + " ago"
                  }) %>
                  <% table.column(title: "GitHub Issue", html: ->(error_log) {
                    if error_log.has_github_issue?
                      link_to(error_log.github_issue_url, target: "_blank", rel: "noopener noreferrer", class: "inline-flex items-center gap-1 text-gray-900 hover:text-gray-700") do
                        content_tag(:svg, content_tag(:path, nil, d: "M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"), fill: "currentColor", viewBox: "0 0 16 16", class: "h-5 w-5") +
                        content_tag(:span, "##{error_log.github_issue_number}", class: "font-medium")
                      end
                    else
                      content_tag(:span, "—", class: "text-gray-400")
                    end
                  }) %>
                  <% table.column(title: "", html: ->(error_log) {
                    render FlatPack::Button::Component.new(
                      text: "View",
                      style: :ghost,
                      size: :sm,
                      url: dashboard_path(error_log)
                    )
                  }) %>
                <% end %>

                <!-- Sentinel element for infinite scroll detection -->
                <div data-infinite-scroll-target="sentinel" style="height: 1px;"></div>

                <!-- Loading indicator -->
                <div data-infinite-scroll-target="loadingIndicator" class="hidden text-center py-4">
                  <div class="inline-flex items-center gap-2 text-gray-600">
                    <svg class="animate-spin h-5 w-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                      <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                      <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                    </svg>
                    <span>Loading more errors...</span>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      </div>
</div>
