<% content_for :page_title, "Error Details" %>

<%= render FlatPack::PageHeader::Component.new(title: "Error Details") %>

<%= render FlatPack::Breadcrumb::Component.new(separator: :chevron) do |breadcrumb| %>
  <% breadcrumb.item(text: "Dashboard", href: dashboard_index_path) %>
  <% breadcrumb.item(text: @error_log.exception_class, href: grouped_dashboard_index_path(exception_class: @error_log.exception_class)) %>
  <% breadcrumb.item(text: "Error Details") %>
<% end %>

      <% if flash[:notice] %>
        <%= render FlatPack::Alert::Component.new(description: flash[:notice], style: :success, class: "mt-8") %>
      <% end %>
      <% if flash[:alert] %>
        <%= render FlatPack::Alert::Component.new(description: flash[:alert], style: :danger, class: "mt-8") %>
      <% end %>

      <div class="mt-8 space-y-6">
        <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
          <% card.header do %>
            <h2 class="text-base font-semibold text-gray-900">Exception Information</h2>
          <% end %>
          <% card.body do %>
            <dl class="grid grid-cols-1 gap-5 sm:grid-cols-2">
              <div>
                <dt class="text-sm font-medium text-gray-500">ID</dt>
                <dd class="mt-1 text-lg font-semibold tracking-tight text-gray-900"><%= @error_log.id %></dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-gray-500">Exception Class</dt>
                <dd class="mt-1 text-lg font-semibold tracking-tight text-red-600"><%= @error_log.exception_class %></dd>
              </div>
              <div class="sm:col-span-2">
                <dt class="text-sm font-medium text-gray-500">Message</dt>
                <dd class="mt-1 text-sm font-mono text-gray-900 break-words bg-gray-50 p-3 rounded border border-gray-200"><%= @error_log.message %></dd>
              </div>
              <div class="sm:col-span-2">
                <dt class="text-sm font-medium text-gray-500">Occurred At</dt>
                <dd class="mt-1 text-lg font-semibold tracking-tight text-gray-900"><%= @error_log.created_at.strftime("%Y-%m-%d %H:%M:%S %Z") %></dd>
              </div>
            </dl>
          <% end %>
        <% end %>

        <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
          <% card.header do %>
            <h2 class="text-base font-semibold text-gray-900">Git Blame Information</h2>
          <% end %>
          <% card.body do %>
            <% if @error_log.has_blame_info? %>
              <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
                <div>
                  <dt class="text-sm font-medium text-gray-500">File</dt>
                  <dd class="mt-1 text-sm text-gray-900"><code class="bg-gray-50 px-2 py-1 rounded border border-gray-200"><%= @error_log.blame_file %></code></dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-gray-500">Line Number</dt>
                  <dd class="mt-1 text-sm text-gray-900"><%= @error_log.blame_line_number %></dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-gray-500">Commit SHA</dt>
                  <dd class="mt-1 text-sm text-gray-900"><code class="bg-gray-50 px-2 py-1 rounded border border-gray-200"><%= @error_log.blame_commit_sha&.first(8) %></code></dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-gray-500">Author</dt>
                  <dd class="mt-1 text-sm text-gray-900"><%= @error_log.blame_author_name %> (<%= @error_log.blame_author_email %>)</dd>
                </div>
                <div class="sm:col-span-2">
                  <dt class="text-sm font-medium text-gray-500">Commit Date</dt>
                  <dd class="mt-1 text-sm text-gray-900"><%= @error_log.blame_commit_date&.strftime("%Y-%m-%d %H:%M:%S %Z") || "N/A" %></dd>
                </div>
              </dl>
              <div class="mt-5">
                <%= render FlatPack::Button::Component.new(text: "Refresh Blame Info", style: :default, size: :sm, url: fetch_blame_dashboard_path(@error_log, force: true), method: :post) %>
              </div>
            <% else %>
              <p class="text-sm text-gray-500 italic">Git blame information could not be fetched automatically, or is not yet available.</p>
              <div class="mt-5">
                <%= render FlatPack::Button::Component.new(text: "Fetch Git Blame", style: :primary, size: :sm, url: fetch_blame_dashboard_path(@error_log), method: :post) %>
              </div>
            <% end %>
          <% end %>
        <% end %>

        <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
          <% card.header do %>
            <h2 class="text-base font-semibold text-gray-900">GitHub Issue</h2>
          <% end %>
          <% card.body do %>
            <% if @error_log.has_github_issue? %>
              <dl class="grid grid-cols-1 gap-x-4 gap-y-4">
                <div>
                  <dt class="text-sm font-medium text-gray-500">Issue Number</dt>
                  <dd class="mt-1 text-sm text-gray-900">#<%= @error_log.github_issue_number %></dd>
                </div>
                <div>
                  <dt class="text-sm font-medium text-gray-500">Issue URL</dt>
                  <dd class="mt-1 text-sm text-gray-900">
                    <%= render FlatPack::Link::Component.new(href: @error_log.github_issue_url, target: "_blank") do %><%= @error_log.github_issue_url %><% end %>
                  </dd>
                </div>
              </dl>
            <% else %>
              <% if @github_configured %>
                <p class="text-sm text-gray-500 italic">No GitHub issue has been created for this error.</p>
                <div class="mt-5 flex flex-wrap gap-3">
                  <%= render FlatPack::Button::Component.new(text: "Create GitHub Issue", style: :primary, size: :sm, url: create_issue_dashboard_path(@error_log), method: :post) %>
                  <% @bowerbird_target_repos.each do |repo| %>
                    <%= render FlatPack::Button::Component.new(
                          text: "Report to #{repo.split('/').last}",
                          style: :default,
                          size: :sm,
                          url: create_issue_dashboard_path(@error_log, target_repo: repo),
                          method: :post
                        ) %>
                  <% end %>
                </div>
              <% else %>
                <p class="text-sm text-gray-500 italic">GitHub integration is not configured. Configure <code class="bg-gray-50 px-2 py-1 rounded border border-gray-200">github_access_token</code>, <code class="bg-gray-50 px-2 py-1 rounded border border-gray-200">github_repo_owner</code>, and <code class="bg-gray-50 px-2 py-1 rounded border border-gray-200">github_repo_name</code> in your initializer.</p>
              <% end %>
            <% end %>
          <% end %>
        <% end %>

        <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
          <% card.header do %>
            <h2 class="text-base font-semibold text-gray-900">Request Details</h2>
          <% end %>
          <% card.body do %>
            <dl class="grid grid-cols-1 gap-x-4 gap-y-4 sm:grid-cols-2">
              <% params_hash = @error_log.params_hash %>
              <div>
                <dt class="text-sm font-medium text-gray-500">Path</dt>
                <dd class="mt-1 text-sm text-gray-900"><%= params_hash["path"] || params_hash[:path] || "N/A" %></dd>
              </div>
              <div>
                <dt class="text-sm font-medium text-gray-500">Method</dt>
                <dd class="mt-1 text-sm text-gray-900"><%= params_hash["method"] || params_hash[:method] || "N/A" %></dd>
              </div>
              <div class="sm:col-span-2">
                <dt class="text-sm font-medium text-gray-500">Query String</dt>
                <dd class="mt-1 text-sm text-gray-900"><%= params_hash["query_string"].presence || params_hash[:query_string].presence || "N/A" %></dd>
              </div>
              <div class="sm:col-span-2">
                <dt class="text-sm font-medium text-gray-500">User Agent</dt>
                <dd class="mt-1 text-sm text-gray-900 break-words"><%= @error_log.user_agent || "N/A" %></dd>
              </div>
              <div class="sm:col-span-2">
                <dt class="text-sm font-medium text-gray-500">Parameters</dt>
                <dd class="mt-1">
                  <pre class="text-xs font-mono text-gray-900 bg-gray-50 p-4 rounded border border-gray-200 overflow-x-auto"><%= JSON.pretty_generate(params_hash["params"] || params_hash[:params] || {}) %></pre>
                </dd>
              </div>
            </dl>
          <% end %>
        <% end %>

        <%= render FlatPack::Card::Component.new(style: :default, hover: :subtle, class: "shadow-md dark:shadow-lg") do |card| %>
          <% card.header do %>
            <h2 class="text-base font-semibold text-gray-900">Stack Trace</h2>
          <% end %>
          <% card.body do %>
            <% if @error_log.backtrace_lines.any? %>
              <pre class="text-xs font-mono bg-slate-800 text-cyan-50 p-4 rounded overflow-x-auto leading-relaxed border border-slate-700"><% @error_log.backtrace_lines.each_with_index do |line, idx| %><span class="text-slate-500 select-none mr-3 inline-block min-w-[36px] text-right"><%= idx + 1 %>.</span> <%= line %>
<% end %></pre>
            <% else %>
              <p class="text-sm text-gray-500 italic">No backtrace available</p>
            <% end %>
          <% end %>
        <% end %>
      </div>
