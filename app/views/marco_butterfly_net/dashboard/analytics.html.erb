<div class="bg-white px-4 py-10 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <!-- Header with Navigation -->
    <div class="px-4 sm:px-6 lg:px-8 mb-8">
      <div class="flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-semibold text-gray-900">Analytics Dashboard</h1>
          <p class="mt-2 text-sm text-gray-700">Monitor error trends, user impact, and performance metrics</p>
        </div>
        <div>
          <%= link_to "← Back to Errors", marco_butterfly_net.dashboard_index_path, class: "text-sm font-medium text-blue-600 hover:text-blue-800" %>
        </div>
      </div>
    </div>

    <!-- Summary KPI Cards -->
    <div class="px-4 sm:px-6 lg:px-8 mb-8">
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4" id="kpi-cards">
        <!-- Cards will be populated by JavaScript -->
        <div class="bg-white overflow-hidden shadow rounded-lg border border-gray-200">
          <div class="px-4 py-5 sm:p-6">
            <dt class="text-sm font-medium text-gray-500 truncate">Total Open Errors</dt>
            <dd class="mt-1 text-3xl font-semibold text-gray-900" id="kpi-open-errors">-</dd>
          </div>
        </div>
        <div class="bg-white overflow-hidden shadow rounded-lg border border-gray-200">
          <div class="px-4 py-5 sm:p-6">
            <dt class="text-sm font-medium text-gray-500 truncate">Users Affected Today</dt>
            <dd class="mt-1 text-3xl font-semibold text-gray-900" id="kpi-affected-users">-</dd>
          </div>
        </div>
        <div class="bg-white overflow-hidden shadow rounded-lg border border-gray-200">
          <div class="px-4 py-5 sm:p-6">
            <dt class="text-sm font-medium text-gray-500 truncate">Mean Time to Resolution</dt>
            <dd class="mt-1 text-3xl font-semibold text-gray-900" id="kpi-mttr">-</dd>
          </div>
        </div>
        <div class="bg-white overflow-hidden shadow rounded-lg border border-gray-200">
          <div class="px-4 py-5 sm:p-6">
            <dt class="text-sm font-medium text-gray-500 truncate">Occurrences Today</dt>
            <dd class="mt-1 text-3xl font-semibold text-gray-900" id="kpi-occurrences">-</dd>
          </div>
        </div>
      </div>
    </div>

    <!-- Charts Grid -->
    <div class="px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
        <!-- Status Breakdown Chart -->
        <div class="bg-white overflow-hidden shadow rounded-lg border border-gray-200">
          <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Error Status Breakdown</h3>
            <div id="status-chart"></div>
          </div>
        </div>

        <!-- Top Errors Chart -->
        <div class="bg-white overflow-hidden shadow rounded-lg border border-gray-200">
          <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Top 10 Most Frequent Errors</h3>
            <div id="top-errors-chart"></div>
          </div>
        </div>

        <!-- Affected Users Over Time -->
        <div class="bg-white overflow-hidden shadow rounded-lg border border-gray-200 lg:col-span-2">
          <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Affected Users Over Time (Last 30 Days)</h3>
            <div id="users-chart"></div>
          </div>
        </div>

        <!-- Error Occurrences Over Time -->
        <div class="bg-white overflow-hidden shadow rounded-lg border border-gray-200 lg:col-span-2">
          <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">Error Occurrences Over Time (Last 30 Days)</h3>
            <div id="occurrences-chart"></div>
          </div>
        </div>

        <!-- New Errors Over Time -->
        <div class="bg-white overflow-hidden shadow rounded-lg border border-gray-200 lg:col-span-2">
          <div class="px-4 py-5 sm:p-6">
            <h3 class="text-lg font-medium text-gray-900 mb-4">New Errors Discovered Over Time (Last 30 Days)</h3>
            <div id="new-errors-chart"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%= javascript_include_tag "marco_butterfly_net/analytics", defer: true %>
