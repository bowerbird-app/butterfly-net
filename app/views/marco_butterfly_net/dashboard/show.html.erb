<div class="bg-white rounded-lg shadow p-6">
  <header class="border-b-2 border-gray-200 pb-4 mb-6">
    <h1 class="text-2xl font-semibold text-gray-900 mb-2">Error Details</h1>
    <%= link_to "← Back to Dashboard", dashboard_index_path, class: "inline-block px-4 py-2 text-sm font-medium rounded border border-gray-300 bg-white text-gray-700 hover:bg-gray-50 transition-colors" %>
  </header>

  <% if flash[:notice] %>
    <div class="px-4 py-3 rounded mb-4 text-sm bg-green-50 border border-green-200 text-green-800"><%= flash[:notice] %></div>
  <% end %>
  <% if flash[:alert] %>
    <div class="px-4 py-3 rounded mb-4 text-sm bg-red-50 border border-red-200 text-red-800"><%= flash[:alert] %></div>
  <% end %>

  <div class="mt-5">
    <section class="mb-8">
      <h2 class="text-base font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-200">Exception Information</h2>
      <dl class="grid grid-cols-[150px_1fr] gap-x-4 gap-y-2">
        <dt class="font-semibold text-gray-600 text-sm">ID</dt>
        <dd class="text-gray-800"><%= @error_log.id %></dd>

        <dt class="font-semibold text-gray-600 text-sm">Exception Class</dt>
        <dd class="font-mono text-red-600 font-medium"><%= @error_log.exception_class %></dd>

        <dt class="font-semibold text-gray-600 text-sm">Message</dt>
        <dd class="font-mono text-sm bg-orange-50 p-3 rounded break-words"><%= @error_log.message %></dd>

        <dt class="font-semibold text-gray-600 text-sm">Occurred At</dt>
        <dd class="text-gray-800"><%= @error_log.created_at.strftime("%Y-%m-%d %H:%M:%S %Z") %></dd>
      </dl>
    </section>

    <section class="mb-8">
      <h2 class="text-base font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-200">Git Blame Information</h2>
      <% if @error_log.has_blame_info? %>
        <dl class="grid grid-cols-[150px_1fr] gap-x-4 gap-y-2">
          <dt class="font-semibold text-gray-600 text-sm">File</dt>
          <dd><code class="bg-gray-100 px-1 rounded"><%= @error_log.blame_file %></code></dd>

          <dt class="font-semibold text-gray-600 text-sm">Line Number</dt>
          <dd class="text-gray-800"><%= @error_log.blame_line_number %></dd>

          <dt class="font-semibold text-gray-600 text-sm">Commit SHA</dt>
          <dd><code class="bg-gray-100 px-1 rounded"><%= @error_log.blame_commit_sha&.first(8) %></code></dd>

          <dt class="font-semibold text-gray-600 text-sm">Author</dt>
          <dd class="text-gray-800"><%= @error_log.blame_author_name %> (<%= @error_log.blame_author_email %>)</dd>

          <dt class="font-semibold text-gray-600 text-sm">Commit Date</dt>
          <dd class="text-gray-800"><%= @error_log.blame_commit_date&.strftime("%Y-%m-%d %H:%M:%S %Z") || "N/A" %></dd>
        </dl>
        <div class="mt-3">
          <%= button_to "Refresh Blame Info", fetch_blame_dashboard_path(@error_log, force: true), method: :post, class: "inline-block px-4 py-2 text-sm font-medium rounded bg-gray-100 border border-gray-300 text-gray-600 hover:bg-gray-200 transition-colors cursor-pointer" %>
        </div>
      <% else %>
        <p class="text-gray-500 italic">No git blame information available.</p>
        <div class="mt-3">
          <%= button_to "Fetch Git Blame", fetch_blame_dashboard_path(@error_log), method: :post, class: "inline-block px-4 py-2 text-sm font-medium rounded bg-blue-600 text-white hover:bg-blue-700 transition-colors cursor-pointer" %>
        </div>
      <% end %>
    </section>

    <section class="mb-8">
      <h2 class="text-base font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-200">GitHub Issue</h2>
      <% if @error_log.has_github_issue? %>
        <dl class="grid grid-cols-[150px_1fr] gap-x-4 gap-y-2">
          <dt class="font-semibold text-gray-600 text-sm">Issue Number</dt>
          <dd class="text-gray-800">#<%= @error_log.github_issue_number %></dd>

          <dt class="font-semibold text-gray-600 text-sm">Issue URL</dt>
          <dd><%= link_to @error_log.github_issue_url, @error_log.github_issue_url, target: "_blank", rel: "noopener noreferrer", class: "text-blue-600 hover:text-blue-800 hover:underline" %></dd>
        </dl>
      <% else %>
        <% if @github_configured %>
          <p class="text-gray-500 italic">No GitHub issue has been created for this error.</p>
          <div class="mt-3">
            <%= button_to "Create GitHub Issue", create_issue_dashboard_path(@error_log), method: :post, class: "inline-block px-4 py-2 text-sm font-medium rounded bg-blue-600 text-white hover:bg-blue-700 transition-colors cursor-pointer" %>
          </div>
        <% else %>
          <p class="text-gray-500 italic">GitHub integration is not configured. Configure <code class="bg-gray-100 px-1 rounded">github_access_token</code>, <code class="bg-gray-100 px-1 rounded">github_repo_owner</code>, and <code class="bg-gray-100 px-1 rounded">github_repo_name</code> in your initializer.</p>
        <% end %>
      <% end %>
    </section>

    <section class="mb-8">
      <h2 class="text-base font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-200">Request Details</h2>
      <dl class="grid grid-cols-[150px_1fr] gap-x-4 gap-y-2">
        <% params_hash = @error_log.params_hash %>
        <dt class="font-semibold text-gray-600 text-sm">Path</dt>
        <dd class="text-gray-800"><%= params_hash["path"] || params_hash[:path] || "N/A" %></dd>

        <dt class="font-semibold text-gray-600 text-sm">Method</dt>
        <dd class="text-gray-800"><%= params_hash["method"] || params_hash[:method] || "N/A" %></dd>

        <dt class="font-semibold text-gray-600 text-sm">Query String</dt>
        <dd class="text-gray-800"><%= params_hash["query_string"].presence || params_hash[:query_string].presence || "N/A" %></dd>

        <dt class="font-semibold text-gray-600 text-sm">User Agent</dt>
        <dd class="text-gray-800"><%= @error_log.user_agent || "N/A" %></dd>

        <dt class="font-semibold text-gray-600 text-sm">Parameters</dt>
        <dd>
          <pre class="font-mono text-xs bg-gray-100 p-3 rounded overflow-x-auto"><%= JSON.pretty_generate(params_hash["params"] || params_hash[:params] || {}) %></pre>
        </dd>
      </dl>
    </section>

    <section class="mb-8">
      <h2 class="text-base font-semibold text-gray-800 mb-4 pb-2 border-b border-gray-200">Stack Trace</h2>
      <% if @error_log.backtrace_lines.any? %>
        <pre class="font-mono text-xs bg-slate-800 text-slate-100 p-4 rounded overflow-x-auto leading-7"><% @error_log.backtrace_lines.each_with_index do |line, idx| %><span class="text-slate-500 select-none mr-3 inline-block min-w-[36px] text-right"><%= idx + 1 %>.</span><%= line %>
<% end %></pre>
      <% else %>
        <p class="text-gray-500 italic">No backtrace available</p>
      <% end %>
    </section>
  </div>
</div>
