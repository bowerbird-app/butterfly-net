{
  "name": "MarcoButterflyNet Rails Engine",
  "image": "mcr.microsoft.com/devcontainers/ruby:1-3.3-bullseye",
  
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "Shopify.ruby-lsp",
        "bung87.rails",
        "aki77.rails-db-schema",
        "hridoy.rails-snippets",
        "misogi.ruby-rubocop",
        "kaiwood.endwise",
        "GitHub.copilot",
        "GitHub.copilot-chat"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.tabSize": 2,
        "ruby.lint": {
          "rubocop": true
        },
        "ruby.format": "rubocop"
      }
    }
  },

  "postCreateCommand": "bash .devcontainer/post-create.sh",
  
  "postStartCommand": "cd test/dummy && bin/rails server -b 0.0.0.0",
  
  "forwardPorts": [3000],
  
  "remoteUser": "vscode"
}
