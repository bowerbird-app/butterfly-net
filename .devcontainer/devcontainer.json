{
  "name": "MarcoButterflyNet Rails Engine",
  "image": "mcr.microsoft.com/devcontainers/ruby:1-3.3-bullseye",
  
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "rebornix.ruby",
        "Shopify.ruby-lsp",
        "misogi.ruby-rubocop",
        "kaiwood.endwise",
        "github.copilot"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "ruby.lint": {
          "rubocop": true
        },
        "ruby.format": "rubocop"
      }
    }
  },

  "postCreateCommand": "bash .devcontainer/post-create.sh",
  
  "forwardPorts": [3000],
  
  "remoteUser": "vscode"
}
